  "answer_key": {
    "purpose": "Regression targets to verify rule registration and checker behavior before encoding all 48 proposition proofs.",
    "positive_tests": [
      {
        "name": "test_Cong2_segment_transfer",
        "goal": "\u2203!D (OnRay(D,A,X) \u2227 AD = BC)",
        "premises": [
          "Ray(A,X)",
          "Segment(BC)"
        ],
        "expected": "accept",
        "justification": "Cong2"
      },
      {
        "name": "test_SAS_triangle_congruence",
        "goal": "Congruent(A,B,C,D,E,F)",
        "premises": [
          "AB = DE",
          "AC = DF",
          "\u2220BAC = \u2220EDF"
        ],
        "expected": "accept",
        "justification": "SAS"
      },
      {
        "name": "test_SSS_triangle_congruence",
        "goal": "Congruent(A,B,C,D,E,F)",
        "premises": [
          "AB = DE",
          "BC = EF",
          "CA = FD"
        ],
        "expected": "accept",
        "justification": "SSS"
      },
      {
        "name": "test_Midpoint",
        "goal": "\u2203M (Between(A,M,B) \u2227 AM = MB)",
        "premises": [
          "A \u2260 B"
        ],
        "expected": "accept",
        "justification": "Midpoint"
      },
      {
        "name": "test_Perpendicular",
        "goal": "\u2203m (P \u2208 m \u2227 m \u27c2 l)",
        "premises": [
          "Point(P)",
          "Line(l)"
        ],
        "expected": "accept",
        "justification": "Perpendicular"
      },
      {
        "name": "test_CircleCircleIntersect",
        "goal": "\u2203X (OnCircle(X,A,B) \u2227 OnCircle(X,C,D))",
        "premises": [
          "Circle(A,B)",
          "Circle(C,D)",
          "CircleCircleIntersectionConditions(A,B,C,D)"
        ],
        "expected": "accept",
        "justification": "CircleCircleIntersect"
      },
      {
        "name": "test_WitnessChoice",
        "goal": "OnCircle(E,A,B) \u2227 OnCircle(E,C,D)",
        "premises": [
          "\u2203X (OnCircle(X,A,B) \u2227 OnCircle(X,C,D))"
        ],
        "expected": "accept",
        "justification": "WitnessChoice",
        "meta": {
          "fresh_symbol": "E",
          "instantiates": "X"
        }
      },
      {
        "name": "test_Prop_I_10",
        "goal": "\u2203M (Between(A,M,B) \u2227 AM = MB)",
        "premises": [
          "A \u2260 B"
        ],
        "expected": "accept",
        "proof": [
          {
            "id": 1,
            "statement": "A \u2260 B",
            "justification": "Given",
            "refs": []
          },
          {
            "id": 2,
            "statement": "\u2203M (Between(A,M,B) \u2227 AM = MB)",
            "justification": "Midpoint",
            "refs": [
              1
            ]
          }
        ]
      },
      {
        "name": "test_Prop_I_12",
        "goal": "\u2203m (C \u2208 m \u2227 m \u27c2 l)",
        "premises": [
          "Point(C)",
          "Line(l)"
        ],
        "expected": "accept",
        "proof": [
          {
            "id": 1,
            "statement": "Point(C)",
            "justification": "Given",
            "refs": []
          },
          {
            "id": 2,
            "statement": "Line(l)",
            "justification": "Given",
            "refs": []
          },
          {
            "id": 3,
            "statement": "\u2203m (C \u2208 m \u2227 m \u27c2 l)",
            "justification": "Perpendicular",
            "refs": [
              1,
              2
            ]
          }
        ]
      }
    ],
    "negative_tests": [
      {
        "name": "reject_canvas_as_justification",
        "premises": [
          "Circle(A,B)",
          "Circle(C,D)"
        ],
        "step": {
          "statement": "\u2203X (OnCircle(X,A,B) \u2227 OnCircle(X,C,D))",
          "justification": "CanvasShowsIntersection",
          "refs": []
        },
        "expected_error": "UNKNOWN_JUSTIFICATION"
      },
      {
        "name": "reject_circle_intersection_without_side_conditions",
        "premises": [
          "Circle(A,B)",
          "Circle(C,D)"
        ],
        "step": {
          "statement": "\u2203X (OnCircle(X,A,B) \u2227 OnCircle(X,C,D))",
          "justification": "CircleCircleIntersect",
          "refs": [
            1,
            2
          ]
        },
        "expected_error": "PREMISE_PATTERN_MISMATCH"
      },
      {
        "name": "reject_nonfresh_witness",
        "premises": [
          "\u2203X \u03c6(X)"
        ],
        "step": {
          "statement": "\u03c6(A)",
          "justification": "WitnessChoice",
          "refs": [
            1
          ],
          "meta": {
            "fresh_symbol": "A",
            "instantiates": "X"
          }
        },
        "expected_error": "NON_FRESH_WITNESS"
      },
      {
        "name": "reject_helper_not_registered",
        "premises": [
          "AB = DE",
          "BC = EF",
          "CA = FD"
        ],
        "step": {
          "statement": "Congruent(A,B,C,D,E,F)",
          "justification": "ExtractAngleFromCongruence",
          "refs": [
            1,
            2,
            3
          ]
        },
        "expected_error": "UNKNOWN_JUSTIFICATION"
      },
      {
        "name": "reject_using_canvas_for_equilateral",
        "premises": [
          "Circle(A,B)",
          "Circle(B,A)",
          "Triangle(A,B,C)"
        ],
        "step": {
          "statement": "Equilateral(A,B,C)",
          "justification": "CanvasEquilateral",
          "refs": []
        },
        "expected_error": "UNKNOWN_JUSTIFICATION"
      }
    ],
    "implementation_checks": [
      "Kernel rules and derived rules must be stored separately.",
      "Derived schemas must enforce side conditions symbolically.",
      "Canvas may suggest witness points, but proof acceptance must never depend on measured coordinates.",
      "Every later proposition should be provable either from kernel + derived rules or from earlier proposition rules."
    ]
  }
}