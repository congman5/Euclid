################################################################################
# .gitignore — Euclid Elements Simulator
################################################################################

# ── IDE / editor ──
/.vs
.vscode/
*.suo
*.user
*.sln.docstates

# ── Python bytecode ──
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ── Distribution / packaging ──
dist/
build/
*.egg-info/
*.egg
*.whl
*.spec

# ── PyInstaller ──
# The .spec is checked in (euclid.spec), but build output is not
/dist/
/build/

# ── Virtual environments ──
.venv/
venv/
env/

# ── Node (not used at runtime, leftover from earlier tooling) ──
node_modules/

# ── Test / coverage ──
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# ── Logs and crash dumps ──
euclid_crash.log
test_out.txt
test_err.txt

# ── Temp / debug scripts (underscore-prefixed at repo root) ──
/_*.py
